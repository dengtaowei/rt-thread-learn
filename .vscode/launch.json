{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "RT-Thread Kernel Startup (from _reset)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/bsp/qemu-vexpress-a9/rtthread.elf",
      "cwd": "${workspaceFolder}/bsp/qemu-vexpress-a9",
      "MIMode": "gdb",
      "miDebuggerPath": "arm-none-eabi-gdb",
      "miDebuggerServerAddress": "localhost:1234",
      "stopAtEntry": false,
      "externalConsole": false,
      "preLaunchTask": "RT-Thread: Run QEMU (gdb wait)",
      "setupCommands": [
        {
          "description": "Enable pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Break at reset entry",
          "text": "-break-insert _reset",
          "ignoreFailures": true
        },
        {
          "description": "Break at kernel startup",
          "text": "-break-insert rtthread_startup",
          "ignoreFailures": true
        },
        {
          "description": "Break at board init",
          "text": "-break-insert rt_hw_board_init",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
